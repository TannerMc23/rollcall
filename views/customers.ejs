<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customers — RollCall</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <h1>RollCall</h1>
      <nav class="header-nav">
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/customers" class="nav-link">Customers</a>
        <a href="/logout" class="logout-link">Log out</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <% if (message) { %>
      <div class="flash flash-<%= messageType %>"><%= message %></div>
    <% } %>

    <div class="panel-header" style="margin-bottom: 16px;">
      <h2 style="margin:0; font-size:20px;">Customers</h2>
      <span class="text-muted" style="font-size:14px;"><%= customers.length %> total</span>
    </div>

    <div class="panel">
      <% if (customers.length === 0) { %>
        <p class="text-muted">No customers yet. They'll appear here as sales are recorded.</p>
      <% } else { %>
        <div class="table">
          <div class="cust-header">
            <span>Customer</span>
            <span>Orders</span>
            <span>Tires purchased</span>
            <span>Total spent</span>
            <span>Last order</span>
          </div>
          <% customers.forEach(function(c) { %>
            <a href="/customers/<%= c.id %>" class="cust-row">
              <span class="cust-name"><%= c.name %></span>
              <span><%= c.order_count %></span>
              <span><%= c.total_tires %></span>
              <span>$<%= Number(c.total_spent).toFixed(2) %></span>
              <span class="text-muted">
                <% if (c.last_order_date) { %>
                  <%= new Date(c.last_order_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                <% } else { %>
                  —
                <% } %>
              </span>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
